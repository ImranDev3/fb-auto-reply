# ============================================
# AutoReply Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Server
PORT=3000

# MongoDB (Get from https://www.mongodb.com/atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fb-auto-reply

# Facebook Messenger (Get from https://developers.facebook.com)
FB_VERIFY_TOKEN=your_custom_verify_token_here
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# JWT Authentication Secret (any random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Google Gemini AI (Get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp (Optional - for WhatsApp support)
# WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
