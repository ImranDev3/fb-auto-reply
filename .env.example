# ===========================================
# FB Auto Reply SaaS - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Port
PORT=3000

# MongoDB Connection String
# Local: mongodb://localhost:27017/fb-auto-reply
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/fb-auto-reply
MONGODB_URI=mongodb://localhost:27017/fb-auto-reply

# Facebook App Credentials
# Get these from https://developers.facebook.com
FB_VERIFY_TOKEN=my_secret_verify_token
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# WhatsApp Cloud API Token (optional - uses FB_PAGE_ACCESS_TOKEN if not set)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# JWT Secret for user authentication
JWT_SECRET=your_super_secret_jwt_key_here
